{
    "openapi": "3.0.0",
    "info": {
        "title": "API文档",
        "description": "买家接口",
        "contact": {
            "name": "API Develop Team"
        },
        "version": "1.0"
    },
    "servers": [
        {
            "url": "/api/member/",
            "description": "开发环境"
        }
    ],
    "components": {
        "schemas": {
            "LoginResponse": {
                "properties": {
                    "token": {
                        "description": "token",
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "OptionResponse": {
                "properties": {
                    "name": {
                        "description": "名称",
                        "type": "string",
                        "example": "name"
                    },
                    "val": {
                        "description": "值",
                        "type": "integer",
                        "example": 1
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "JWT 认证信息",
                "name": "Authorization",
                "in": "header",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    }
}